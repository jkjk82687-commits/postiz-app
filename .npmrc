only-built-dependencies[]=@parcel/watcher
only-built-dependencies[]=@prisma/client
only-built-dependencies[]=@prisma/engines
only-built-dependencies[]=@scarf/scarf
only-built-dependencies[]=@sentry-internal/node-cpu-profiler
only-built-dependencies[]=@sentry/cli
only-built-dependencies[]=@swc/core
only-built-dependencies[]=bcrypt
only-built-dependencies[]=bufferutil
only-built-dependencies[]=core-js
only-built-dependencies[]=core-js-pure
only-built-dependencies[]=esbuild
only-built-dependencies[]=prisma
only-built-dependencies[]=protobufjs
only-built-dependencies[]=sharp
only-built-dependencies[]=unrs-resolver
only-built-dependencies[]=utf-8-validate
